void setup() {
  Serial.begin(9600);
  while (!Serial) {delay(100);}
  
  // Enable Voltages
  pinMode(pinOUT, OUTPUT); // DAC-Output
  pinMode(pinPOT, INPUT); // Spannung am Poti einlesen
  pinMode(pinRES, INPUT); // Spannung am Vorwiderstand einlesen


  // Set up Bluetooth connection
  PhyphoxBLE::start(ssid, &PLA[0], sizeof(PLA)); // phyphox-Verbindung starten
  //PhyphoxBLE::setMTU(185); // Byte-Max hochsetzen
  PhyphoxBLE::configHandler=&simon_says; // phyphox-Input ermöglichen

  // Set default values
  bvoltagePOT = 4095;
  bvoltageMIN = 50;
  bvoltageMAX = 254;
  bvoltageINC = 1;
  cad = 40;
  bvoltageOUT = bvoltageMIN + 10;
}

void loop() {
  // Actual purpose
  PhyphoxBLE::poll();
  delay(25);
  switch(mode) {
    case 2: // auto mode
      bvoltageLOW = reverse_cal_mapping(voltageLOW);
      bvoltageHIGH = reverse_cal_mapping(voltageHIGH);
      if (bvoltageLOW == bvoltageHIGH) {bvoltageHIGH++; period=1;}
      cad = (int) max(period*1000/(bvoltageHIGH-bvoltageLOW) + 0.5, 20.0);
      periodInUse = period;
      for (int bvoltageOUT=bvoltageLOW; bvoltageOUT <= bvoltageHIGH; bvoltageOUT=bvoltageOUT+bvoltageINC) {
        voltageOUT = cal_OUT_mapping(bvoltageOUT, 1);
        dacWrite(pinOUT, bvoltageOUT);
        bvoltageRES = analogRead(pinRES);
        voltageRES = cal_IN_mapping(bvoltageRES);
        currentRES = current_mapping(voltageRES);
        PhyphoxBLE::write(voltageOUT, currentRES);
        delay(cad);
        if(mode == 0 || mode == 1 || period != periodInUse){break;}
      }
      break;
    case 0: // manual mode
      bvoltagePOT = analogRead(pinPOT);
      bvoltageOUT = map_voltage_to_bit(bvoltagePOT, bvoltageMIN, bvoltageMAX);
      voltageOUT = cal_OUT_mapping(bvoltageOUT, 0);
      dacWrite(pinOUT, bvoltageOUT);
      bvoltageRES = analogRead(pinRES);
      voltageRES = cal_IN_mapping(bvoltageRES);
      currentRES = current_mapping(voltageRES);
      Serial.print(bvoltageRES);
      Serial.print(", ");
      Serial.print(voltageOUT);
      Serial.print(", ");
      Serial.println(currentRES);
      PhyphoxBLE::write(voltageOUT, currentRES);
      break;
    case 1: // target voltage mode
      bvoltageOUT = reverse_cal_mapping(voltageTARGET);
      voltageOUT = cal_OUT_mapping(bvoltageOUT, 0);
      dacWrite(pinOUT, bvoltageOUT);
      bvoltageRES = analogRead(pinRES);
      voltageRES = cal_IN_mapping(bvoltageRES);
      currentRES = current_mapping(voltageRES);
      PhyphoxBLE::write(voltageOUT, currentRES);
      break;
    default: dacWrite(pinOUT, 0); voltageOUT = 0; currentRES = 0; PhyphoxBLE::write(voltageOUT, currentRES);
  }
}

void simon_says() {
  // Read array
  uint8_t my_array[16];
  PhyphoxBLE::read(&my_array[0], 16);
  memcpy(&mode, &my_array[0], 2);
  memcpy(&voltageTARGET, &my_array[2], 4);
  memcpy(&period, &my_array[6], 2);
  memcpy(&voltageLOW, &my_array[8], 4);
  memcpy(&voltageHIGH, &my_array[12], 4);

  // Safety net for certain variables
  voltageTARGET = max( min(voltageTARGET, (float) 3.2), (float) 0.0 );
  voltageLOW = max( min(voltageLOW, (float) 3.2), (float) 0.0 );
  voltageHIGH = max( min(voltageHIGH, (float) 3.2), (float) 0.0 );
}

int reverse_cal_mapping(float i) {
  return( (int) (i*255/3.3 + 0.5) );
}

int map_voltage_to_bit(int input, int U_min, int U_max) {
  float output;
  output = (U_min-U_max)*input/4095 + U_max + 0.5;
  return(min(U_max, (int) output));
}

float current_mapping(float input) {
  float output;
  output = (voltageOUT-input)*10;
  return(output);
}

