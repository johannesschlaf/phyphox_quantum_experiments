<phyphox xmlns="http://phyphox.org/xml" xmlns:editor="http://phyphox.org/editor/xml" version="1.19" editor:version="1.0" locale="en">
    <title>Eve</title>
    <category>BB84 Analogy</category>
    <color>a0ee90</color>
    <description>Measures polarisation states and sends the respective measurement data. Version 4.1.</description>
    <icon format="base64"></icon>
    
    <translations>
	    <translation locale="de">
            <title>Eve</title>
            <category>BB84-Analogie</category>
            <description>Misst Polarisationszustände und verschickt wieder entsprechende Messdaten. Version 4.1.</description>
            <string original="Measuring and sending polarisation states">Polarisationszustände messen und verschicken</string>
            <string original="Measure quantum state">Quantenzustand messen</string>
            <string original="Measuring base:">Messbasis:</string>
            <string original="Measured state:">Gemessener Zustand:</string>
            <string original="Bit:">Bit:</string>
            <string original="Counter:">Zähler:</string>
	    </translation>
    </translations>
	
    <data-containers>
        <!--Random number generator-->
        <container size="1" static="false">acc</container>
        <container size="0" static="false">acc_array</container>
        <container size="1" static="false" init="0.132">plant1</container>
        <container size="1" static="false" init="0">noise1</container>
        <container size="0" static="false">noise_array1</container>
        <container size="1" static="false" init="0.133">plant2</container>
        <container size="1" static="false" init="0">noise2</container>
        <container size="0" static="false">noise_array2</container>
        <container size="1" static="true" init="3.95">phi</container>

        <!--Algorithm and Graphics-->
        <container size="1" static="false">hue</container>
        <container size="0" static="false">hue_array</container>
        <container size="1" static="true" init="1000000">factor1</container>
        <container size="1" static="true" init="100000">factor2</container>
        <container size="0" static="false">number_array</container>
        <container size="1" static="false">color</container>
        <container size="1" static="false" init="0">val_button</container>
        <container size="1" static="false" init="0">step_counter</container>
        <container size="0" static="false" init="0">graphx</container>
        <container size="0" static="false" init="0">graphy</container>
        <container size="0" static="false">mapx</container>
        <container size="0" static="false">mapy</container>
        <container size="10" static="false">mapz</container>

        <container size="1">base_candidate</container>
        <container size="0">base_array</container>
        <container size="1">decision_candidate</container>
        <container size="0">decision_array</container>
        <container size="0">measurement_array</container>

        <container size="0" static="false">dummy</container>
    </data-containers>

    <input>
        <sensor average="false" type="accelerometer">
            <output component="x">acc</output>
        </sensor>
        <camera auto_exposure="true" feature="photometric" x1="0.4" x2="0.6" y1="0.4" y2="0.6">
            <output component="hue">hue</output>
        </camera>
    </input>

    <output>
    </output>

    <analysis onUserInput="false">
        <!--Generate noise-->
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant1</input>
            <output>plant1</output>
        </formula>
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant2</input>
            <output>plant2</output>
        </formula>
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant1</input>
            <output>noise1</output>
        </formula>
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant2</input>
            <output>noise2</output>
        </formula>

        <!--Generate new data only when button is pressed-->
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">acc</input>
            <input type="empty" as="false"/>
            <output clear="false">acc_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">hue</input>
            <input type="empty" as="false"/>
            <output clear="false">hue_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="true" as="true">noise1</input>
            <input type="empty" as="false"/>
            <output clear="false">noise_array1</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="true" as="true">noise2</input>
            <input type="empty" as="false"/>
            <output clear="false">noise_array2</output>
        </if>
      
        <!--Process new data-->
        <formula formula="round( ([1_]%360)/90 )%4">
            <input clear="false">hue_array</input>
            <output>number_array</output>
        </formula>

        <!--Generating a random base and a random decision-->
        <formula formula="(floor(abs([1])*[2]) + [3])%2">
            <input clear="false">acc_array</input>
            <input clear="false">factor1</input>
            <input clear="false">noise_array1</input>
            <output>base_candidate</output>
        </formula>
        <formula formula="(floor(abs([1])*[2]) + [3])%2">
            <input clear="false">acc_array</input>
            <input clear="false">factor2</input>
            <input clear="false">noise_array2</input>
            <output>decision_candidate</output>
        </formula>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">base_candidate</input>
            <input type="empty" as="false"/>
            <output clear="false">base_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">decision_candidate</input>
            <input type="empty" as="false"/>
            <output clear="false">decision_array</output>
        </if>
        
        <!--Measuring the polarisation state-->
        <formula formula="[1_]*abs(([1_]%2) - [2_]) + ((([1_]%2)+[2_]+1)%2)*((([2_]+1)%2) + 2*[3_])">
            <input clear="false">number_array</input>
            <input clear="false">base_array</input>
            <input clear="false">decision_array</input>
            <output>measurement_array</output>
        </formula>

        <!--Calculating the right color-->
        <formula formula="[1_]/3">
            <input clear="false">measurement_array</input>
            <output>color</output>
        </formula>

        <!--Preparing data for ColorMap-->
        <map>
            <input as="mapWidth" type="value">3</input>
            <input as="minX" type="value">-1</input>
            <input as="maxX" type="value">1</input>
            <input as="mapHeight" type="value">3</input>
            <input as="minY" type="value">-1</input>
            <input as="maxY" type="value">1</input>
            <input as="x" clear="false">graphx</input>
            <input as="y" clear="false">graphy</input>
            <input as="z" clear="false">color</input>
            <output as="x">mapx</output>
            <output as="y">mapy</output>
            <output as="z">dummy</output>
        </map>

        <const>
            <input as="value" clear="false">color</input>
            <input as="length" type="value">9</input>
            <output>mapz</output>
        </const>

        <count>
            <input clear="false">acc_array</input>
            <output>step_counter</output>
        </count>
        <append>
            <input type="value">0</input>
            <output clear="true">val_button</output>
        </append>
    </analysis>

    <views>
        <view label="Measuring and sending polarisation states">
            <camera-gui label="" exposure_adjustment_level="3" />
            <button label="Measure quantum state">
                <input type="value">1</input>
                <output>val_button</output>
            </button>
            <separator height="1"/>
            <separator color="white"/>
            <graph label="Quantum Interface" showColorScale="false" mapColor1="ff0000" mapColor2="80ff00" mapColor3="00ffff" mapColor4="8000ff" munitX="" unitY="" minZ="0" maxZ="1" scaleMinZ="fixed" scaleMaxZ="fixed" aspectRatio="1" style="map" mapWidth="3" partialUpdate="true">
                <input axis="x">mapx</input>
                <input axis="y">mapy</input>
                <input axis="z">mapz</input>
            </graph>
            <separator height="1"/>
            <value label="Measuring base:" size="2" precision="0" scientific="false" unit="" factor="1" >
                <input>base_array</input>
                <map min="0" max="0">+/-</map>
                <map min="1" max="1">h/v</map>
            </value>
            <separator height="1"/>
            <value label="Measured state:" size="2" precision="0" scientific="false" unit="" factor="1" >
                <input>measurement_array</input>
                <map min="0" max="0">h</map>
                <map min="1" max="1">-</map>
                <map min="2" max="2">v</map>
                <map min="3" max="3">+</map>
            </value>
            <separator height="1"/>
            <value label="Bit:" size="2" precision="0" scientific="false" unit="" factor="1" >
                <input>measurement_array</input>
                <map min="0" max="1">0</map>
                <map min="2" max="3">1</map>
            </value>
            <separator height="1"/>
            <value label="Counter:" size="2" precision="0" scientific="false" unit="" factor="1" >
                <input>step_counter</input>
            </value>
        </view>
    </views>

    <export>
    </export>
</phyphox>