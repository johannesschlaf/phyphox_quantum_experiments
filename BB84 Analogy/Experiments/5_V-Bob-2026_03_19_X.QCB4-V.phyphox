<phyphox xmlns="http://phyphox.org/xml" xmlns:editor="http://phyphox.org/editor/xml" version="1.19" locale="en">
    <title>V-Bob</title>
    <category>BB84 Analogy (advanced level)</category>
    <color>ffee90</color>
    <description>Receives and measures polarisation states. Version 4.1.</description>
    <icon format="base64"></icon>

    <translations>
	    <translation locale="de">
            <title>V-Bob</title>
            <category>BB84-Analogie für Fortgeschrittene</category>
            <description>Erhält und misst Polarisationszustände. Version 4.1.</description>
            <string original="Measuring polarisation states">Polarisationszustände messen</string>
            <string original="Measure quantum state">Quantenzustand messen</string>
            <string original="Measuring base:">Messbasis:</string>
            <string original="Measured state:">Gemessener Zustand:</string>
            <string original="Bit:">Bit:</string>
            <string original="Counter:">Zähler:</string>
            <string original="Setting the channel">Kanal einstellen</string>
            <string original="Receive signal from:">Signal erhalten von:</string>
            <string original="Change to Alice and reset experiment">Zu Alice wechseln und Experiment zurücksetzen</string>
            <string original="Change to Eve and reset experiment">Zu Eve wechseln und Experiment zurücksetzen</string>
	    </translation>
    </translations>
	
    <data-containers>
        <!--Random number generator-->
        <container size="1" static="false">acc</container>
        <container size="0" static="false">acc_array</container>
        <container size="1" static="false" init="0.130">plant1</container>
        <container size="1" static="false" init="0">noise1</container>
        <container size="0" static="false">noise_array1</container>
        <container size="1" static="false" init="0.131">plant2</container>
        <container size="1" static="false" init="0">noise2</container>
        <container size="0" static="false">noise_array2</container>
        <container size="1" static="true" init="3.95">phi</container>

        <!--Algorithm and Graphics-->
        <container size="1" static="false">hue</container>
        <container size="0" static="false">hue_array</container>
        <container size="1" static="true" init="1000000">factor1</container>
        <container size="1" static="true" init="100000">factor2</container>
        <container size="0" static="false">number_array</container>
        <container size="1" static="false" init="0">val_button</container>
        <container size="1" static="false" init="0">step_counter</container>

        <container size="1">base_candidate</container>
        <container size="0">base_array</container>
        <container size="1">decision_candidate</container>
        <container size="0">decision_array</container>
        <container size="0">measurement_array</container>

        <!--Controlled pseudo random numbers-->
        <container size="1" static="false" init="0.657">plant_color</container>
        <container size="1" static="false" init="1">pseudo_random_number</container>
        <container size="1" static="false" init="0.657">next_plant_color</container>
        <container size="1" static="false" init="1">mode_AliceEve</container>
        <container size="1" static="false" init="0">val_AliceEve_button</container>

        <container size="0" static="false">dummy</container>
    </data-containers>

    <input>
        <sensor average="false" type="accelerometer">
            <output component="x">acc</output>
        </sensor>
        <camera auto_exposure="true" feature="photometric" x1="0.4" x2="0.6" y1="0.4" y2="0.6">
            <output component="hue">hue</output>
        </camera>
    </input>

    <output>
    </output>

    <analysis onUserInput="false">
        <!--Change mode if applicable-->
        <if equal="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0.657</input>
            <input type="value" as="true">1</input>
            <input type="empty" as="false"/>
            <output clear="false">mode_AliceEve</output>
        </if>
        <if equal="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0.42</input>
            <input type="value" as="true">2</input>
            <input type="empty" as="false"/>
            <output clear="false">mode_AliceEve</output>
        </if>
        <if greater="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0</input>
            <input clear="false" as="true">val_AliceEve_button</input>
            <input type="empty" as="false"/>
            <output clear="false">plant_color</output>
        </if>
        <if greater="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0</input>
            <input type="empty" as="true"/>
            <input clear="false" as="false">acc_array</input>
            <output clear="true">acc_array</output>
        </if>
        <if greater="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0</input>
            <input type="empty" as="true"/>
            <input clear="false" as="false">hue_array</input>
            <output clear="true">hue_array</output>
        </if>
        <if greater="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0</input>
            <input type="empty" as="true"/>
            <input clear="false" as="false">number_array</input>
            <output clear="true">number_array</output>
        </if>
        <if greater="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0</input>
            <input type="empty" as="true"/>
            <input clear="false" as="false">base_array</input>
            <output clear="true">base_array</output>
        </if>
        <if greater="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0</input>
            <input type="empty" as="true"/>
            <input clear="false" as="false">decision_array</input>
            <output clear="true">decision_array</output>
        </if>
        <if greater="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0</input>
            <input type="empty" as="true"/>
            <input clear="false" as="false">measurement_array</input>
            <output clear="true">measurement_array</output>
        </if>
        <if greater="true">
            <input clear="false">val_AliceEve_button</input>
            <input type="value">0</input>
            <input type="value" as="true">0</input>
            <input type="empty" as="false"/>
            <output clear="false">step_counter</output>
        </if>
        <append>
            <input type="value">0</input>
            <output clear="true">val_AliceEve_button</output>
        </append>
        
        <!--Generate noise-->
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant1</input>
            <output>plant1</output>
        </formula>
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant2</input>
            <output>plant2</output>
        </formula>
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant1</input>
            <output>noise1</output>
        </formula>
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant2</input>
            <output>noise2</output>
        </formula>

        <!--Generate new data only when button is pressed-->
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">acc</input>
            <input type="empty" as="false"/>
            <output clear="false">acc_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">hue</input>
            <input type="empty" as="false"/>
            <output clear="false">hue_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="true" as="true">noise1</input>
            <input type="empty" as="false"/>
            <output clear="false">noise_array1</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="true" as="true">noise2</input>
            <input type="empty" as="false"/>
            <output clear="false">noise_array2</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">next_plant_color</input>
            <input type="empty" as="false"/>
            <output clear="false">plant_color</output>
        </if>

        <!--Generate pseudo-random number and its potential successor-->
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant_color</input>
            <output clear="true">pseudo_random_number</output>
        </formula>
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant_color</input>
            <output clear="true">next_plant_color</output>
        </formula>
      
        <!--Process new data-->
        <formula formula="round( (([1_]-45)%360 )/90 + 4-[2])%4">
            <input clear="false">hue_array</input>
            <input clear="false">pseudo_random_number</input>
            <output>number_array</output>
        </formula>

        <!--Generating a random base and a random decision-->
        <formula formula="(floor(abs([1])*[2]) + [3])%2">
            <input clear="false">acc_array</input>
            <input clear="false">factor1</input>
            <input clear="false">noise_array1</input>
            <output>base_candidate</output>
        </formula>
        <formula formula="(floor(abs([1])*[2]) + [3])%2">
            <input clear="false">acc_array</input>
            <input clear="false">factor2</input>
            <input clear="false">noise_array2</input>
            <output>decision_candidate</output>
        </formula>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">base_candidate</input>
            <input type="empty" as="false"/>
            <output clear="false">base_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">decision_candidate</input>
            <input type="empty" as="false"/>
            <output clear="false">decision_array</output>
        </if>
        
        <!--Measuring the polarisation state-->
        <formula formula="[1_]*abs(([1_]%2) - [2_]) + ((([1_]%2)+[2_]+1)%2)*((([2_]+1)%2) + 2*[3_])">
            <input clear="false">number_array</input>
            <input clear="false">base_array</input>
            <input clear="false">decision_array</input>
            <output>measurement_array</output>
        </formula>

        <count>
            <input clear="false">acc_array</input>
            <output>step_counter</output>
        </count>
        <append>
            <input type="value">0</input>
            <output clear="true">val_button</output>
        </append>
    </analysis>

    <views>
        <view label="Measuring polarisation states">
            <camera-gui label="" exposure_adjustment_level="3" />
            <button label="Measure quantum state">
                <input type="value">1</input>
                <output>val_button</output>
            </button>
            <separator height="1"/>
            <value label="Measuring base:" size="3" precision="0" scientific="false" unit="" factor="1" >
                <input>base_array</input>
                <map min="0" max="0">+/-</map>
                <map min="1" max="1">h/v</map>
            </value>
            <separator height="1"/>
            <value label="Measured state:" size="3" precision="0" scientific="false" unit="" factor="1" >
                <input>measurement_array</input>
                <map min="0" max="0">h</map>
                <map min="1" max="1">-</map>
                <map min="2" max="2">v</map>
                <map min="3" max="3">+</map>
            </value>
            <separator height="1"/>
            <value label="Bit:" size="3" precision="0" scientific="false" unit="" factor="1" >
                <input>measurement_array</input>
                <map min="0" max="1">0</map>
                <map min="2" max="3">1</map>
            </value>
            <separator height="1"/>
            <value label="Counter:" size="3" precision="0" scientific="false" unit="" factor="1" >
                <input>step_counter</input>
            </value>
        </view>
        <view label="Setting the channel">
            <value label="Receive signal from:" size="1.2" color="yellow" precision="0" scientific="false" unit="" factor="1" >
                <input>mode_AliceEve</input>
                <map min="1" max="1">Alice</map>
                <map min="2" max="2">Eve</map>
            </value>
            <separator height="1"/>
            <separator color="white"/>
            <button label="Change to Alice and reset experiment">
                <input type="value">0.657</input>
                <output>val_AliceEve_button</output>
            </button>
            <separator height="1"/>
            <button label="Change to Eve and reset experiment">
                <input type="value">0.42</input>
                <output>val_AliceEve_button</output>
            </button>
        </view>
    </views>

    <export>
    </export>
</phyphox>