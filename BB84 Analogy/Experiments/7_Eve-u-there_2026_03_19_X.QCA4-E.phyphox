<phyphox xmlns="http://phyphox.org/xml" xmlns:editor="http://phyphox.org/editor/xml" version="1.19" locale="en">
    <title>Eve, u there?</title>
    <category>BB84 Analogy (advanced level)</category>
    <color>ffee90</color>
    <description>Generates random polarisation states and may or may not trigger Eve. Version 4.1.</description>
    <icon format="base64"></icon>
    
    <translations>
        <translation locale="de">
        <title>Eve, u there?</title>
        <category>BB84-Analogie für Fortgeschrittene</category>
        <description>Generiert zufällige Polarisationszustände und aktiviert möglicherweise Eve. Version 4.1.</description>
			<string original="Generating polarisation states">Polarisationszustände generieren</string>
			<string original="Generate new quantum state">Neuen Quantenzustand generieren</string>
			<string original="Counter:">Zähler:</string>
			<string original="Sent polarisation states">Gesendete Polarisationszustände</string>
			<string original="Base:">Basis:</string>
			<string original="Polarisation state:">Polarisation:</string>
			<string original="Bit:">Bit:</string>
			<string original="Eve, u there?">Eve, u there?</string>
			<string original="No!">Nein!</string>
			<string original="Yes!">Ja!</string>
			<string original="Switch to Yes/No">Zu Ja/Nein wechseln</string>
        </translation>
    </translations>
	
    <data-containers>
        <!--Random number generator-->
        <container size="1" static="false">acc</container>
        <container size="0" static="false">acc_array</container>
        <container size="1" static="false" init="0.128">plant</container>
        <container size="1" static="false" init="0">noise</container>
        <container size="0" static="false">noise_array</container>
        <container size="1" static="true" init="3.95">phi</container>

        <!--Algorithm and Graphics-->
        <container size="1" static="true" init="1000000">factor1</container>
        <container size="0" static="false">number_array</container>
        <container size="1" static="false">color</container>
        <container size="1" static="false" init="0">val_button</container>
        <container size="1" static="false" init="0">step_counter</container>
        <container size="0" static="false" init="0">graphx</container>
        <container size="0" static="false" init="0">graphy</container>
        <container size="0" static="false">mapx</container>
        <container size="0" static="false">mapy</container>
        <container size="10" static="false">mapz</container>

        <!--Controlled Pseudo Random Numbers-->
        <container size="1" static="false" init="0.657">plant_color</container>
        <container size="1" static="false" init="1">pseudo_random_number</container>
        <container size="1" static="false" init="0.657">next_plant_color</container>

        <!--Eve-->
        <container size="1" static="false" init="0.132">plant_Eve_1</container>
        <container size="1" static="false" init="0">noise_Eve_1</container>
        <container size="0" static="false">noise_array_Eve_1</container>
        <container size="1" static="false" init="0.133">plant_Eve_2</container>
        <container size="1" static="false" init="0">noise_Eve_2</container>
        <container size="0" static="false">noise_array_Eve_2</container>
        <container size="1" static="true" init="10000000">factor_Eve_1</container>
        <container size="1" static="true" init="100000">factor_Eve_2</container>
        <container size="1" static="false">base_candidate</container>
        <container size="0">base_array</container>
        <container size="1">decision_candidate</container>
        <container size="0">decision_array</container>
        <container size="0">measurement_array</container>
        <container size="1" static="false" init="0">mode_AliceEve</container>
        <container size="1" static="false" init="0">val_AliceEve_button</container>
        <container size="0" static="false">number_array_send</container>

        <!--20 numbers-->
        <container size="1" static="false" init="99">n00</container>
        <container size="1" static="false" init="99">n01</container>
        <container size="1" static="false" init="99">n02</container>
        <container size="1" static="false" init="99">n03</container>
        <container size="1" static="false" init="99">n04</container>
        <container size="1" static="false" init="99">n05</container>
        <container size="1" static="false" init="99">n06</container>
        <container size="1" static="false" init="99">n07</container>
        <container size="1" static="false" init="99">n08</container>
        <container size="1" static="false" init="99">n09</container>
        <container size="1" static="false" init="99">n10</container>
        <container size="1" static="false" init="99">n11</container>
        <container size="1" static="false" init="99">n12</container>
        <container size="1" static="false" init="99">n13</container>
        <container size="1" static="false" init="99">n14</container>
        <container size="1" static="false" init="99">n15</container>
        <container size="1" static="false" init="99">n16</container>
        <container size="1" static="false" init="99">n17</container>
        <container size="1" static="false" init="99">n18</container>
        <container size="1" static="false" init="99">n19</container>

        <container size="0" static="false">dummy</container>
    </data-containers>

    <input>
        <sensor average="false" type="accelerometer">
            <output component="x">acc</output>
        </sensor>
    </input>

    <output>
    </output>

    <analysis onUserInput="false">
        <!--Change mode if applicable-->
        <formula formula="([1]+[2])%2">
	        <input clear="false">mode_AliceEve</input>
			<input clear="false">val_AliceEve_button</input>
			<output clear="false">mode_AliceEve</output>
        </formula>

        <!--Generate noise-->
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant</input>
            <output>plant</output>
        </formula>
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant</input>
            <output>noise</output>
        </formula>
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant_Eve_1</input>
            <output>plant_Eve_1</output>
        </formula>
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant_Eve_2</input>
            <output>plant_Eve_2</output>
        </formula>
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant_Eve_1</input>
            <output>noise_Eve_1</output>
        </formula>
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant_Eve_2</input>
            <output>noise_Eve_2</output>
        </formula>

        
        <!--Generate new data only when button is pressed-->
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">acc</input>
            <input type="empty" as="false"/>
            <output clear="false">acc_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="true" as="true">noise</input>
            <input type="empty" as="false"/>
            <output clear="false">noise_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="true" as="true">noise_Eve_1</input>
            <input type="empty" as="false"/>
            <output clear="false">noise_array_Eve_1</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="true" as="true">noise_Eve_2</input>
            <input type="empty" as="false"/>
            <output clear="false">noise_array_Eve_2</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">next_plant_color</input>
            <input type="empty" as="false"/>
            <output clear="false">plant_color</output>
        </if>

        <!--Generate pseudo-random number and its potential successor-->
        <formula formula="floor(10000*[1])%4">
            <input clear="false">plant_color</input>
            <output clear="true">pseudo_random_number</output>
        </formula>
        <formula formula="[1]*[2]*(1-[2])">
            <input clear="false">phi</input>
            <input clear="false">plant_color</input>
            <output>next_plant_color</output>
        </formula>

        <!--Generating random numbers and polarisation states-->
        <formula formula="(floor(abs([1_])*[2]) + [3_])%4">
            <input clear="false">acc_array</input>
            <input clear="false">factor1</input>
            <input clear="false">noise_array</input>
            <output>number_array</output>
        </formula>

	    <!--Generating a random base and a random decision-->
        <formula formula="(floor(abs([1])*[2]) + [3])%2">
            <input clear="false">acc_array</input>
            <input clear="false">factor_Eve_1</input>
            <input clear="false">noise_array_Eve_1</input>
            <output>base_candidate</output>
        </formula>
        <formula formula="(floor(abs([1])*[2]) + [3])%2">
            <input clear="false">acc_array</input>
            <input clear="false">factor_Eve_2</input>
            <input clear="false">noise_array_Eve_2</input>
            <output>decision_candidate</output>
        </formula>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">base_candidate</input>
            <input type="empty" as="false"/>
            <output clear="false">base_array</output>
        </if>
        <if equal="true">
            <input clear="false">val_button</input>
            <input type="value">1</input>
            <input clear="false" as="true">decision_candidate</input>
            <input type="empty" as="false"/>
            <output clear="false">decision_array</output>
        </if>

	    <!--Measuring the polarisation state-->
        <formula formula="[1_]*abs(([1_]%2) - [2_]) + ((([1_]%2)+[2_]+1)%2)*((([2_]+1)%2) + 2*[3_])">
            <input clear="false">number_array</input>
            <input clear="false">base_array</input>
            <input clear="false">decision_array</input>
            <output>measurement_array</output>
        </formula>

        <!--Sending based on mode-->
        <if equal="true">
            <input clear="false">mode_AliceEve</input>
            <input type="value">1</input>
            <input clear="false" as="true">measurement_array</input>
            <input clear="false" as="false">number_array</input>
            <output clear="true">number_array_send</output>
        </if>

		<!--Calculating the right color-->
        <formula formula="(([1_]+[2])%4)/3">
            <input clear="false">number_array_send</input>
            <input clear="false">pseudo_random_number</input>
            <output>color</output>
        </formula>

        <!--Preparing data for ColorMap-->
        <map>
            <input as="mapWidth" type="value">3</input>
            <input as="minX" type="value">-1</input>
            <input as="maxX" type="value">1</input>
            <input as="mapHeight" type="value">3</input>
            <input as="minY" type="value">-1</input>
            <input as="maxY" type="value">1</input>
            <input as="x" clear="false">graphx</input>
            <input as="y" clear="false">graphy</input>
            <input as="z" clear="false">color</input>
            <output as="x">mapx</output>
            <output as="y">mapy</output>
            <output as="z">dummy</output>
        </map>
        <const>
            <input as="value" clear="false">color</input>
            <input as="length" type="value">9</input>
            <output>mapz</output>
        </const>

        <count>
            <input clear="false">acc_array</input>
            <output>step_counter</output>
        </count>
        <append>
            <input type="value">0</input>
            <output clear="true">val_button</output>
        </append>
		<append>
            <input type="value">0</input>
            <output clear="true">val_AliceEve_button</output>
        </append>

        <!--Getting multiple steps of Alice to show simulateously-->
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">0</input>
            <input type="value" as="length">1</input>
            <output append="true">n00</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">1</input>
            <input type="value" as="length">1</input>
            <output append="true">n01</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">2</input>
            <input type="value" as="length">1</input>
            <output append="true">n02</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">3</input>
            <input type="value" as="length">1</input>
            <output append="true">n03</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">4</input>
            <input type="value" as="length">1</input>
            <output append="true">n04</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">5</input>
            <input type="value" as="length">1</input>
            <output append="true">n05</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">6</input>
            <input type="value" as="length">1</input>
            <output append="true">n06</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">7</input>
            <input type="value" as="length">1</input>
            <output append="true">n07</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">8</input>
            <input type="value" as="length">1</input>
            <output append="true">n08</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">9</input>
            <input type="value" as="length">1</input>
            <output append="true">n09</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">10</input>
            <input type="value" as="length">1</input>
            <output append="true">n10</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">11</input>
            <input type="value" as="length">1</input>
            <output append="true">n11</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">12</input>
            <input type="value" as="length">1</input>
            <output append="true">n12</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">13</input>
            <input type="value" as="length">1</input>
            <output append="true">n13</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">14</input>
            <input type="value" as="length">1</input>
            <output append="true">n14</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">15</input>
            <input type="value" as="length">1</input>
            <output append="true">n15</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">16</input>
            <input type="value" as="length">1</input>
            <output append="true">n16</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">17</input>
            <input type="value" as="length">1</input>
            <output append="true">n17</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">18</input>
            <input type="value" as="length">1</input>
            <output append="true">n18</output>
        </subrange>
        <subrange>
            <input keep="true">number_array</input>
            <input type="value" as="from">19</input>
            <input type="value" as="length">1</input>
            <output append="true">n19</output>
        </subrange>
    </analysis>

    <views>
        <view label="Generating polarisation states">
            <graph label="Quantum Interface" showColorScale="false" mapColor1="ffbf00" mapColor2="00ff40" mapColor3="0040ff" mapColor4="ff00bf" munitX="" unitY="" minZ="0" maxZ="1" scaleMinZ="fixed" scaleMaxZ="fixed" aspectRatio="1" style="map" mapWidth="3" partialUpdate="true">
                <input axis="x">mapx</input>
                <input axis="y">mapy</input>
                <input axis="z">mapz</input>
            </graph>
            <separator height="1"/>
            <button label="Generate new quantum state">
                <input type="value">1</input>
                <output>val_button</output>
            </button>
            <separator height="1"/>
            <value label="Counter:" size="2" precision="0" scientific="false" unit="" factor="1" >
                <input>step_counter</input>
            </value>
        </view>
        <view label="Sent polarisation states">
            <info label="1" bold="true" size="1.2" color="yellow"/>
            <value label="Base:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n00</input>
                    <map min="0" max="0">h/v</map>
                    <map min="1" max="1">+/-</map>
                    <map min="2" max="2">h/v</map>
                    <map min="3" max="3">+/-</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Polarisation state:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n00</input>
                    <map min="0" max="0">h</map>
                    <map min="1" max="1">-</map>
                    <map min="2" max="2">v</map>
                    <map min="3" max="3">+</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Bit:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n00</input>
                    <map min="0" max="1">0</map>
                    <map min="2" max="3">1</map>
                    <map min="99" max="99">?</map>
            </value>
            <separator color="white"/>

            <info label="2" bold="true" size="1.2" color="yellow"/>
            <value label="Base:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n01</input>
                    <map min="0" max="0">h/v</map>
                    <map min="1" max="1">+/-</map>
                    <map min="2" max="2">h/v</map>
                    <map min="3" max="3">+/-</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Polarisation state:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n01</input>
                    <map min="0" max="0">h</map>
                    <map min="1" max="1">-</map>
                    <map min="2" max="2">v</map>
                    <map min="3" max="3">+</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Bit:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n01</input>
                    <map min="0" max="1">0</map>
                    <map min="2" max="3">1</map>
                    <map min="99" max="99">?</map>
            </value>
            <separator color="white"/>

            <info label="3" bold="true" size="1.2" color="yellow"/>
            <value label="Base:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n02</input>
                    <map min="0" max="0">h/v</map>
                    <map min="1" max="1">+/-</map>
                    <map min="2" max="2">h/v</map>
                    <map min="3" max="3">+/-</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Polarisation state:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n02</input>
                    <map min="0" max="0">h</map>
                    <map min="1" max="1">-</map>
                    <map min="2" max="2">v</map>
                    <map min="3" max="3">+</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Bit:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n02</input>
                    <map min="0" max="1">0</map>
                    <map min="2" max="3">1</map>
                    <map min="99" max="99">?</map>
            </value>
            <separator color="white"/>

            <info label="4" bold="true" size="1.2" color="yellow"/>
            <value label="Base:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n03</input>
                    <map min="0" max="0">h/v</map>
                    <map min="1" max="1">+/-</map>
                    <map min="2" max="2">h/v</map>
                    <map min="3" max="3">+/-</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Polarisation state:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n03</input>
                    <map min="0" max="0">h</map>
                    <map min="1" max="1">-</map>
                    <map min="2" max="2">v</map>
                    <map min="3" max="3">+</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Bit:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n03</input>
                    <map min="0" max="1">0</map>
                    <map min="2" max="3">1</map>
                    <map min="99" max="99">?</map>
            </value>
            <separator color="white"/>

            <info label="5" bold="true" size="1.2" color="yellow"/>
            <value label="Base:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n04</input>
                    <map min="0" max="0">h/v</map>
                    <map min="1" max="1">+/-</map>
                    <map min="2" max="2">h/v</map>
                    <map min="3" max="3">+/-</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Polarisation state:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n04</input>
                    <map min="0" max="0">h</map>
                    <map min="1" max="1">-</map>
                    <map min="2" max="2">v</map>
                    <map min="3" max="3">+</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Bit:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n04</input>
                    <map min="0" max="1">0</map>
                    <map min="2" max="3">1</map>
                    <map min="99" max="99">?</map>
            </value>
            <separator color="white"/>

            <info label="6" bold="true" size="1.2" color="yellow"/>
            <value label="Base:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n05</input>
                    <map min="0" max="0">h/v</map>
                    <map min="1" max="1">+/-</map>
                    <map min="2" max="2">h/v</map>
                    <map min="3" max="3">+/-</map>
                    <map min="99" max="99">?</map>
            </value>
            <value label="Polarisation state:" size="2" precision="0" scientific="false" unit="" factor="1">
                    <input>n05</input>
                    <map min="0" max="0">h</map>
